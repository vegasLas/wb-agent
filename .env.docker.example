# ==========================================
# WB Agent - Docker Environment Variables
# ==========================================
# Copy this file to .env.docker and fill in your values
# Usage: docker-compose --env-file .env.docker up -d

# ------------------------------------------
# Database Configuration
# ------------------------------------------
POSTGRES_USER=wbagent
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=wbagent
DATABASE_URL=postgresql://wbagent:your_secure_password_here@postgres:5432/wbagent?schema=public

# ------------------------------------------
# Server Configuration
# ------------------------------------------
NODE_ENV=production
PORT=3001
FRONTEND_URL=http://localhost:3000

# ------------------------------------------
# Security (REQUIRED)
# ------------------------------------------
# Generate a 64+ character hex string for encryption
# You can generate one with: openssl rand -hex 32
COOKIE_ENCRYPTION_KEY=your_64_character_hex_string_here_minimum_64_chars_long
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# ------------------------------------------
# Telegram Bot (Optional but recommended)
# ------------------------------------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ------------------------------------------
# YooKassa Payments (Optional)
# ------------------------------------------
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key

# ------------------------------------------
# WB API Configuration
# ------------------------------------------
WB_API_BASE_URL=https://seller-supply.wildberries.ru

# ------------------------------------------
# Proxy List (Optional)
# Format: ip:port:user:pass:timezone,ip:port:user:pass:timezone
PROXY_LIST=

# ------------------------------------------
# Monitoring & Maintenance
# ------------------------------------------
RUN_MONITORING_CLEANUP=true
# Comma-separated Telegram user IDs allowed during maintenance
TECHNICAL_MODE_USER_IDS=

# ------------------------------------------
# Redis (Optional - for future caching)
# ------------------------------------------
# REDIS_URL=redis://redis:6379
