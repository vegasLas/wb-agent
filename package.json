{
  "name": "@wb-monorepo/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev:frontend": "nx serve frontend",
    "dev:backend": "nx serve backend",
    "dev": "nx run-many -t serve -p frontend backend",
    "build": "nx run-many -t build -p frontend backend",
    "build:frontend": "nx build frontend",
    "build:backend": "nx build backend",
    "deploy:frontend": "nx deploy frontend",
    "deploy:landing": "cd apps/landing && npm run build && scp -r ../../dist/apps/landing/* wbsupplier:/var/www/html/wboi/",
    "lint": "nx run-many -t lint -p frontend backend",
    "type-check": "nx type-check frontend",
    "test": "nx run-many -t test -p backend -- --forceExit",
    "test:frontend": "nx run-many -t test -p frontend",
    "docker:build": "docker build -t vegasslas/myapp-private:wb-test -f apps/backend/Dockerfile apps/backend",
    "docker:build:push": "docker buildx build --platform linux/amd64 -t vegasslas/myapp-private:wb-test -f apps/backend/Dockerfile apps/backend --push",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f backend"
  },
  "private": true,
  "dependencies": {
    "dompurify": "^3.4.0",
    "marked": "^18.0.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nx/devkit": "22.5.4",
    "@nx/eslint": "22.5.4",
    "@nx/eslint-plugin": "22.5.4",
    "@nx/jest": "22.5.4",
    "@nx/js": "22.5.4",
    "@nx/node": "22.5.4",
    "@nx/playwright": "22.5.4",
    "@nx/vite": "22.5.4",
    "@nx/vitest": "22.5.4",
    "@nx/vue": "22.5.4",
    "@nx/web": "22.5.4",
    "@nx/workspace": "22.5.4",
    "@playwright/test": "^1.36.0",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/marked": "^5.0.2",
    "@types/node": "20.19.9",
    "@typescript-eslint/parser": "^8.40.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-playwright": "^1.6.2",
    "jiti": "2.4.2",
    "nx": "22.5.4",
    "prettier": "~3.6.2",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0"
  },
  "workspaces": [
    "apps/*",
    "libs/*"
  ]
}
