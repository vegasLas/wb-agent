{
  "name": "@wb-monorepo/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev:frontend": "nx serve frontend",
    "dev:backend": "nx serve api",
    "dev": "nx run-many -t serve -p frontend api",
    "build": "nx run-many -t build -p frontend api",
    "lint": "nx run-many -t lint -p frontend api",
    "test": "nx run-many -t test -p api -- --forceExit",
    "test:frontend": "nx run-many -t test -p frontend",
    "db:generate": "prisma generate --schema=apps/backend/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=apps/backend/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=apps/backend/prisma/schema.prisma",
    "docker:build": "docker buildx build -t vegasslas/myapp-private:wb-test -f apps/backend/Dockerfile .",
    "docker:build:push": "docker buildx build --platform linux/amd64 -t vegasslas/myapp-private:wb-test -f apps/backend/Dockerfile . && docker push vegasslas/myapp-private:wb-test",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f backend"
  },
  "private": true,
  "dependencies": {
