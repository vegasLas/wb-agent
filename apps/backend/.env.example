# API Environment Variables
# Copy this file to .env and fill in your actual values

NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/wb_database?schema=public"

# Encryption (64 character hex string for AES-256)
COOKIE_ENCRYPTION_KEY=your-64-character-hex-encoded-encryption-key-here-32-bytes

# JWT Configuration (required for browser auth)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long-change-in-production
JWT_EXPIRES_IN=7d

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# YooKassa Payment
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key

# WB API
WB_API_BASE_URL=https://seller-supply.wildberries.ru

# Proxy List (optional, comma-separated: ip:port:username:password:timezone)
# PROXY_LIST=1.2.3.4:8080:user:pass:180,5.6.7.8:8080:user2:pass2:180

# Technical Mode (optional, comma-separated user IDs allowed during maintenance)
# TECHNICAL_MODE_USER_IDS=123456789,987654321
