{
  "name": "api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/api/src",
  "projectType": "application",
  "tags": ["backend"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx ts-node --project apps/api/tsconfig.app.json apps/api/src/main.ts",
        "cwd": "."
      }
    },
    "serve:dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx nodemon --exec ts-node --project apps/api/tsconfig.app.json apps/api/src/main.ts",
        "cwd": "."
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{options.outputPath}"],
      "options": {
        "command": "tsc -p apps/api/tsconfig.app.json --outDir dist/apps/api"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/api/jest.config.ts"
      }
    }
  }
}
