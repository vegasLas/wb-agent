{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "es2022",
    "lib": ["es2022"],
    "strict": true,
    "skipLibCheck": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "isolatedModules": true,
    "importHelpers": true,
    "paths": {
      "@wb-monorepo/shared": ["./libs/shared/src/index.ts"],
      "@wb-monorepo/shared/*": ["./libs/shared/src/*"]
    }
  },
  "files": [],
  "include": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.spec.json"
    }
  ]
}
