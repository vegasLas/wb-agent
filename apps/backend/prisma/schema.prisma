generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============== USER & ACCOUNTS ==============

enum Permission {
  PROMOTIONS
  FEEDBACKS
  REPORTS
  ADVERTS
  SUPPLIES
}

enum SubscriptionTier {
  FREE
  LITE
  PRO
  MAX
}

enum AuthProvider {
  EMAIL
  TELEGRAM
  VK
  LEGACY
}

model User {
  id                    Int               @id @default(autoincrement())
  wbAuthUpdatedAt       DateTime?
  autobookingCount      Int               @default(0)
  maxAccounts           Int               @default(1)
  trialUsedAt           DateTime?
  subscriptions         UserSubscription[]
  supplyTriggers        SupplyTrigger[]
  payments              Payment[]
  autobookings          Autobooking[]
  supplierApiKey        SupplierApiKey?

  agreeTerms             Boolean                 @default(false)
  supplierId             String?
  supplierName           String?
  selectedAccountId      String?
  envInfo                Json?
  createdAt              DateTime                @default(now())
  envInfoUpdatedAt       DateTime?
  accounts               Account[]
  bonuses                Bonus[]
  autobookingReschedules AutobookingReschedule[]
  mpstatsToken           String?
  skuCards               WbSkuCard[]
  admins                 Admin[]
  refreshTokens          RefreshToken[]
  authTokens             AuthToken[]
  identities             UserIdentity[]
  linkCodes              LinkCode[]

  profile  Profile?
  telegram Telegram?
}

model UserSubscription {
  id        Int              @id @default(autoincrement())
  userId    Int
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier      SubscriptionTier
  startedAt DateTime         @default(now())
  endedAt   DateTime?
  createdAt DateTime         @default(now())

  @@index([userId])
}

model Profile {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Telegram {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatId       String?  @unique
  username     String?
  languageCode String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model RefreshToken {
  id         String    @id @default(uuid())
  tokenHash  String    @unique
  userId     Int
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  replacedBy String?

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
}

model WbSkuCard {
  id          String   @id @default(uuid())
  nmID        Int
  imtID       Int?
  nmUUID      String?
  subjectID   Int?
  subjectName String?
  vendorCode  String?
  brand       String?
  title       String?
  description String?
  image       String?
  favourite   Boolean  @default(false)
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([nmID, userId])
  @@index([userId])
  @@index([nmID])
}

model UserIdentity {
  id              Int          @id @default(autoincrement())
  userId          Int
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider        AuthProvider
  providerId      String? // external ID: vk user id, telegram id, etc.
  email           String? // normalized email (for EMAIL provider)
  passwordHash    String? // bcrypt hash (for EMAIL / LEGACY)
  emailVerifiedAt DateTime?
  metadata        Json? // provider-specific extra data
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([provider, providerId])
  @@unique([provider, email])
  @@index([userId])
  @@index([email])
}

model AuthToken {
  id        String    @id @default(uuid())
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  type      String // 'EMAIL_VERIFICATION' | 'PASSWORD_RESET'
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
}

model LinkCode {
  id        String    @id @default(uuid())
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([code])
  @@index([expiresAt])
}

model Account {
  id                 String     @id @default(uuid())
  userId             Int
  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  wbCookies          String?
  wbLocalStorage     String? // Encrypted localStorage JSON string
  phoneWb            String?
  selectedSupplierId String?
  lastUpdatedCookie  DateTime?
  suppliers          Supplier[]
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@index([userId])
}

model Supplier {
  id           Int          @id @default(autoincrement())
  supplierId   String
  supplierName String
  permissions  Permission[] @default([])
  accountId    String
  account      Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now())

  @@unique([supplierId, accountId])
  @@index([accountId])
  @@index([supplierId])
}

// ============== AUTOBOOKING ==============

enum SupplyTypeDb {
  BOX
  MONOPALLETE
  SUPERSAFE
}

model Autobooking {
  id                   String     @id @default(uuid())
  userId               Int
  supplierId           String
  user                 User       @relation(fields: [userId], references: [id])
  draftId              String
  warehouseId          Int
  transitWarehouseId   Int?
  transitWarehouseName String?
  supplyType           String
  dateType             String
  startDate            DateTime?
  endDate              DateTime?
  customDates          DateTime[]
  completedDates       DateTime[] @default([])
  maxCoefficient       Float      @default(0)
  monopalletCount      Int?
  status               String     @default("ACTIVE")
  bookedAt             DateTime?
  bookedDate           DateTime?
  supplyId             String?
  supplyIdUpdatedAt    DateTime?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  @@index([userId])
  @@index([status])
  @@index([draftId])
}

model AutobookingReschedule {
  id             String     @id @default(uuid())
  userId         Int
  user           User       @relation(fields: [userId], references: [id])
  supplierId     String
  warehouseId    Int
  dateType       String
  startDate      DateTime?
  endDate        DateTime?
  currentDate    DateTime
  customDates    DateTime[] @default([])
  completedDates DateTime[] @default([])
  maxCoefficient Float      @default(0)
  status         String     @default("ACTIVE")
  supplyType     String
  supplyId       String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([userId])
  @@index([status])
  @@index([supplierId])
}

// ============== TRIGGERS ==============

model SupplyTrigger {
  id                 String     @id @default(uuid())
  userId             Int
  user               User       @relation(fields: [userId], references: [id])
  warehouseIds       Int[]
  supplyTypes        String[]
  isActive           Boolean    @default(true)
  checkInterval      Int        @default(180)
  maxCoefficient     Float      @default(0)
  lastNotificationAt DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  searchMode         String     @default("TODAY")
  startDate          DateTime?
  endDate            DateTime?
  selectedDates      DateTime[] @default([])
  status             String     @default("RELEVANT")

  @@index([userId])
  @@index([isActive])
}

// ============== PAYMENTS ==============

model Payment {
  id             String           @id @default(uuid())
  userId         Int
  user           User             @relation(fields: [userId], references: [id])
  amount         Float
  currency       String           @default("RUB")
  status         String
  paymentId      String           @unique
  tariffId       String
  tier           SubscriptionTier @default(FREE)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  idempotencyKey String           @unique
  paidAt         DateTime?

  @@index([userId])
  @@index([status])
}

// ============== API KEYS ==============

model SupplierApiKey {
  id        String   @id @default(uuid())
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isActive  Boolean  @default(true)
  apiKey    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ============== WAREHOUSE DATA ==============

model WarehouseCoefficient {
  id             String       @id @default(uuid())
  warehouseId    Int
  warehouseName  String
  date           DateTime     @db.Date
  supplyType     SupplyTypeDb
  maxCoefficient Float
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([warehouseId, date, supplyType])
  @@index([warehouseId])
  @@index([date])
}

// ============== BONUSES ==============

model Bonus {
  id            String    @id @default(uuid())
  userId        Int
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bonusType     String
  bonusValue    Int
  description   String?
  isApplied     Boolean   @default(false)
  appliedAt     DateTime?
  expiresAt     DateTime?
  promotionCode String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([userId, bonusType])
  @@index([userId])
  @@index([bonusType])
  @@index([isApplied])
}

// ============== RATE LIMITING ==============

model RateLimit {
  id         String     @id @default(uuid())
  userId     String
  type       String
  timestamps DateTime[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([userId, type])
  @@index([updatedAt])
}

// ============== SUPPLIER HISTORY ==============

model UserSupplierHistory {
  id         Int      @id @default(autoincrement())
  supplierId String   @unique
  createdAt  DateTime @default(now())

  @@index([supplierId])
}

model AiConversation {
  id        String   @id @default(uuid())
  userId    Int
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages AiMessage[]

  @@index([userId, updatedAt])
}

model AiMessage {
  id             String   @id @default(uuid())
  conversationId String
  role           String
  content        String   @db.Text
  toolCalls      Json?
  toolResults    Json?
  attachments    Json?
  createdAt      DateTime @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Admin {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model AiUsageLog {
  id               String   @id @default(uuid())
  userId           Int
  feature          String
  model            String
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  cost             Float
  costCurrency     String   @default("USD")
  conversationId   String?
  messageId        String?
  metadata         Json?
  createdAt        DateTime @default(now())

  @@index([userId, createdAt])
  @@index([feature, createdAt])
  @@index([model, createdAt])
  @@index([createdAt])
}

model FeedbackSettings {
  id                String   @id @default(uuid())
  userId            Int
  supplierId        String
  autoAnswerEnabled Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([userId, supplierId])
  @@index([userId])
  @@index([supplierId])
}

model FeedbackProductSetting {
  id                String   @id @default(uuid())
  userId            Int
  supplierId        String
  nmId              Int
  autoAnswerEnabled Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([userId, supplierId, nmId])
  @@index([userId])
  @@index([supplierId])
  @@index([nmId])
}

model FeedbackAutoAnswer {
  id               String    @id @default(uuid())
  userId           Int
  supplierId       String
  feedbackId       String
  nmId             Int
  feedbackText     String    @default("")
  answerText       String
  valuation        Int       @default(5)
  status           String    @default("PENDING")
  trustFactor      String    @default("buyout")
  feedbackTextCons String?
  feedbackTextPros String?
  productName      String?
  productBrand     String?
  supplierArticle  String?
  userName         String?
  purchaseDate     BigInt?
  feedbackDate     BigInt?
  photos           Json?
  video            Json?
  postedAt         DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([userId, supplierId, feedbackId])
  @@index([userId, supplierId, nmId])
  @@index([status])
  @@index([createdAt])
}

model FeedbackRejectedAnswer {
  id                 String   @id @default(uuid())
  userId             Int
  supplierId         String
  feedbackId         String
  nmId               Int
  feedbackText       String   @default("")
  rejectedAnswerText String
  valuation          Int      @default(5)
  productName        String?
  aiAnalysis         String?
  mistakeCategory    String?
  userFeedback       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId, supplierId])
  @@index([feedbackId])
  @@index([createdAt])
  @@index([nmId])
}

model FeedbackGoodsGroup {
  id         String   @id @default(uuid())
  userId     Int
  supplierId String
  nmIds      Int[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, supplierId])
}

enum FeedbackRuleMode {
  skip
  instruction
}

model FeedbackRule {
  id          String           @id @default(uuid())
  userId      Int
  supplierId  String
  nmIds       Int[]
  minRating   Int?
  maxRating   Int?
  keywords    String[]
  instruction String?
  mode        FeedbackRuleMode @default(skip)
  enabled     Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([userId])
  @@index([supplierId])
}
