{
  "name": "@wb-monorepo/backend",
  "version": "0.0.1",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.app.json --outDir ../../dist/apps/api || true",
    "serve": "ts-node --project tsconfig.app.json src/main.ts",
    "serve:dev": "nodemon --exec ts-node --project tsconfig.app.json src/main.ts",
    "test": "jest --config jest.config.ts",
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "db:studio": "prisma studio --schema=prisma/schema.prisma",
    "migrate:alias": "node scripts/migrate-to-alias.js"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "@telegram-apps/init-data-node": "^2.0.10",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "https-proxy-agent": "^7.0.6",
    "jsonwebtoken": "^9.0.2",
    "node-fetch": "^2.7.0",
    "node-schedule": "^2.1.1",
    "node-telegram-bot-api": "^0.67.0",
    "playwright": "^1.58.0",
    "prisma": "^6.5.0",
    "socks-proxy-agent": "^9.0.0",
    "tslib": "^2.3.0",
    "winston": "^3.17.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "20.19.9",
    "@types/node-fetch": "^2.6.13",
    "@types/node-schedule": "^2.1.7",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2"
  }
}
